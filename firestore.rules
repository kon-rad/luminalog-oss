rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Soul Constellation day-centroids hold RAW journal-text embedding vectors.
      // Server-only (Admin SDK bypasses rules). Explicitly denied to clients as
      // defense-in-depth — v2 rules already do not cascade the parent allow to
      // subcollections, but this guards against a future blanket wildcard.
      match /constellationCentroids/{dayIndex} {
        allow read, write: if false;
      }
    }

    // Journal entries: top-level collection keyed by a userId field.
    match /journals/{journalId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Public marketing waitlist (landing page). Anyone may add their email
    // (the doc id is the lowercased email, so re-submits upsert idempotently),
    // but the list is never publicly readable or deletable — it holds PII.
    match /waitlist/{email} {
      allow read, delete: if false;
      allow create, update: if request.resource.data.email is string
        && request.resource.data.email == email
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$');
    }

    // Chats: top-level collection keyed by a userId field.
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Messages subcollection: inherit ownership from the parent chat.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }

    // Daily reports: indexed by user (uid) and date. Owner-read only; server-write only.
    match /dailyReports/{uid}/days/{date} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // written only by the server (Admin SDK bypasses rules)
    }
  }
}
