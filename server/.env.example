PORT=3200
NODE_ENV=development
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
CHROMA_URL=http://localhost:8000
TOGETHER_AI_API_KEY=
TOGETHER_EMBEDDING_MODEL=togethercomputer/m2-bert-80M-8k-retrieval
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
REVENUECAT_WEBHOOK_SECRET=
# 32-byte base64 master key that wraps each user's data key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=
# Optional — Hume Expression Measurement (entry emotion scoring). Unset = scoring skipped.
HUME_API_KEY=
# Optional — Unsplash Search (shareable card background). Unset = gradient fallback.
UNSPLASH_ACCESS_KEY=


# Soul Constellation NFT (Base). All optional in config.ts — placeholders only here.
# CDP (Coinbase Developer Platform) Server Wallet — backend-custodied user wallets.
#   ID/SECRET: portal.cdp.coinbase.com → API Keys → Create secret API key
#   WALLET_SECRET: portal → Wallets → Non-custodial Wallet → Security → Generate Wallet Secret
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Base chain: minter EOA (deploys/owns the contract), RPC, deployed contract address.
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN=base-sepolia   # set to 'base' for mainnet (with mainnet contract/RPC/minter)
BASE_MINTER_PRIVATE_KEY=
SOULBOUND_CONTRACT_ADDRESS=
# Public base for tokenURI; must match the contract's baseURI.
NFT_METADATA_BASE_URL=https://api.luminalog.com/v1/nft/
# Enforce AI-data-sharing consent (5.1.1/5.1.2): 403 on AI routes without a
# recorded users/{uid}.consent.aiDataSharing===true. ON now that the iOS consent
# screen + gate ship (feat/ai-consent-screen).
ENFORCE_AI_CONSENT=true
# Deepgram — voice/video journal-entry transcription (nova-3). Optional: if unset,
# entry transcription falls back to Together Whisper. Text dictation stays on-device.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- Server LLM provider switch (ADR-0085/0087) ---
# `morpheus` (default) routes chat/summary/entry-AI/daily-report to the Morpheus
# decentralized TEE marketplace; `together` uses the legacy provider. NO cross-provider
# fallback — a failed call is retried against the same provider. STT (Whisper/Deepgram)
# is unaffected (always Together/Deepgram).
AI_PROVIDER=morpheus
# Legacy Together chat model (only used when AI_PROVIDER=together).
TOGETHER_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# Morpheus gateway credentials + the ONE global chat model. Swap MORPHEUS_CHAT_MODEL
# to change the model app-wide (e.g. gemini-3.1-pro-preview, GPT-5.5, glm-5.2,
# deepseek-v4-pro, llama-3.3-70b). claude-opus-4.8 = best quality for journaling.
MORPHEUS_API_KEY=
MORPHEUS_BASE_URL=https://api.mor.org/api/v1
MORPHEUS_CHAT_MODEL=claude-opus-4.8
MORPHEUS_EMBEDDING_MODEL=text-embedding-bge-m3