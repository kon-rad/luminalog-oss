# ──────────────────────────────────────────────────────────────
# Secrets & credentials — NEVER commit these
# ──────────────────────────────────────────────────────────────
# Environment files (keep the *.example / *.sample templates)
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.SAMPLE

# Firebase / Google service credentials
# Wildcards (not exact names) so variants like old-/copy-/.bak can't slip through.
**/*GoogleService-Info*.plist
**/*google-services*.json
**/service-account-secret.json
**/*service-account*.json
**/*serviceAccount*.json
**/firebase-adminsdk*.json

# Apple signing / keys
**/AuthKey_*.p8
*.p8
*.p12
*.mobileprovision
*.cer
*.certSigningRequest

# Generic key material
*.pem
*.key
*.keystore
*.jks
secrets/
*.secret

# ──────────────────────────────────────────────────────────────
# macOS
# ──────────────────────────────────────────────────────────────
.DS_Store
.thumbnail

# ──────────────────────────────────────────────────────────────
# iOS / Xcode  (ios/)
# ──────────────────────────────────────────────────────────────
# The Xcode project is generated by XcodeGen from project.yml
*.xcodeproj
!**/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
xcuserdata/
*.xcuserstate
DerivedData/
build/
.build/
.swiftpm/

# ──────────────────────────────────────────────────────────────
# Node / TypeScript server  (server/) & landing build
# ──────────────────────────────────────────────────────────────
node_modules/
dist/
out/
.next/
*.js.map
*.tsbuildinfo
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────────────────────────────────────────────────────────
# Logs / temp / editor
# ──────────────────────────────────────────────────────────────
*.log
tmp/
.cache/
.idea/
.vscode/

# Brainstorming scratch (visual companion)
.superpowers/

# Local ChromaDB backups (never commit)
deploy/chroma/chroma-backups/
chroma-backups/

# Claude Code local worktrees/state
.claude/
